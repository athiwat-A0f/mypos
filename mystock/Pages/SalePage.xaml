<Page x:Class="mystock.Pages.SalePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:mystock.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SalePage">

    <Grid Background="#F4F6F9">

        <Grid Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!-- ===================== -->
            <!-- PRODUCT ZONE -->
            <!-- ===================== -->

            <Border Grid.Column="0"
         Background="White"
         CornerRadius="10"
         Padding="20"
         Margin="0 0 15 0">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="15"
                         ShadowDepth="2"
                         Opacity="0.2"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="📦 ขายสินค้า"
                    FontSize="22"
                    FontWeight="Bold"
                    Margin="0 0 0 10"/>

                    <ScrollViewer>

                        <ItemsControl x:Name="ProductGrid">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>

                                <DataTemplate>

                                    <Button Width="250"
            Height="140"
            Margin="8"
            Foreground="White"
            FontSize="20"
            BorderThickness="0"
            Click="Product_Click"
            Tag="{Binding}">

                                        <Button.Template>

                                            <ControlTemplate TargetType="Button">

                                                <Border x:Name="card"
                        CornerRadius="14"
                        Padding="10">

                                                    <!-- Gradient Background -->
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#4A90E2" Offset="0"/>
                                                            <GradientStop Color="#6A5ACD" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>

                                                    <StackPanel VerticalAlignment="Center">

                                                        <!-- Product Name -->
                                                        <TextBlock Text="{Binding ProductName}"
                                   FontWeight="Bold"
                                   FontSize="20"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0 0 0 6"/>

                                                        <!-- Price -->
                                                        <TextBlock TextAlignment="Center"
                                   FontSize="16"
                                   Margin="0 0 0 6">

                            <Run Text="ราคา "/>
                            <Run Text="{Binding Price}"/>
                            <Run Text=" บาท"/>

                                                        </TextBlock>

                                                        <!-- Stock -->
                                                        <TextBlock Text="{Binding Stock, StringFormat=คงเหลือ {0}}"
                                   TextAlignment="Center"
                                   FontSize="15"
                                   FontWeight="SemiBold">

                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">

                                                                    <Setter Property="Foreground" Value="White"/>

                                                                    <Style.Triggers>

                                                                        <!-- Low Stock -->
                                                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                                            <Setter Property="Foreground" Value="Yellow"/>
                                                                        </DataTrigger>

                                                                        <!-- Out of Stock -->
                                                                        <DataTrigger Binding="{Binding IsOutOfStock}" Value="True">
                                                                            <Setter Property="Foreground" Value="#FF3B30"/>
                                                                        </DataTrigger>

                                                                    </Style.Triggers>

                                                                </Style>
                                                            </TextBlock.Style>

                                                        </TextBlock>

                                                    </StackPanel>

                                                </Border>

                                                <!-- Hover effect -->
                                                <ControlTemplate.Triggers>

                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="card" Property="Opacity" Value="0.9"/>
                                                        <Setter TargetName="card" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>

                                                </ControlTemplate.Triggers>

                                            </ControlTemplate>

                                        </Button.Template>

                                    </Button>

                                </DataTemplate>

                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </ScrollViewer>

                </StackPanel>

            </Border>


            <!-- ===================== -->
            <!-- BILL ZONE -->
            <!-- ===================== -->

            <Border Grid.Column="1"
         Background="White"
         CornerRadius="10"
         Padding="20">


                <Border.Effect>
                    <DropShadowEffect BlurRadius="15"
                                      ShadowDepth="2"
                                      Opacity="0.2"/>
                </Border.Effect>

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- TITLE -->

                    <TextBlock Text="📝 รายการขาย"  
                    FontSize="20"
                    FontWeight="Bold"
                    Margin="0 0 0 10"/>


                    <!-- BILL LIST -->

                    <ListView Grid.Row="1"
                   x:Name="SaleGrid"
                   ScrollViewer.VerticalScrollBarVisibility="Auto" d:ItemsSource="{d:SampleData ItemCount=5}" >

                        <ListView.ItemTemplate>

                            <DataTemplate>

                                <Border Margin="4"
            Padding="10"
            CornerRadius="10"
            Background="White"
            BorderBrush="#F1F1F1"
            BorderThickness="1">

                                    <Grid>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition MinWidth="220"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- PRODUCT -->
                                        <StackPanel>

                                            <TextBlock Text="{Binding ProductName}"
                           FontWeight="Bold"
                           FontSize="16"
                           Margin="0 0 0 6"/>

                                            <!-- QTY CONTROL -->
                                            <StackPanel Orientation="Horizontal">

                                                <!-- minus -->
                                                <Button Width="30"
        Height="30"
        Background="#F8BBD0"
        BorderThickness="0"
        Click="DecreaseQty_Click"
        Tag="{Binding}">

                                                    <TextBlock Text=""
               FontFamily="Segoe MDL2 Assets"
               FontSize="14"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

                                                </Button>

                                                <!-- qty -->
                                                <TextBox Width="45"
                             Height="30"
                             Margin="6 0"
                             Text="{Binding Qty, UpdateSourceTrigger=PropertyChanged}"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             FontSize="15"
                             PreviewTextInput="Qty_PreviewTextInput"
                             LostFocus="Qty_LostFocus"
                             Tag="{Binding}"/>

                                                <!-- plus -->
                                                <Button Width="30"
        Height="30"
        Background="#F48FB1"
        BorderThickness="0"
        Click="IncreaseQty_Click"
        Tag="{Binding}">

                                                    <TextBlock Text=""
               FontFamily="Segoe MDL2 Assets"
               FontSize="14"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"/>

                                                </Button>

                                            </StackPanel>

                                        </StackPanel>

                                        <!-- TOTAL -->
                                        <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">

                                            <TextBlock Text="รวม"
                           FontSize="12"
                           Foreground="Gray"
                           HorizontalAlignment="Right"/>

                                            <TextBlock Text="{Binding Total, StringFormat=N2}"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Right"/>

                                        </StackPanel>


                                        <!-- DELETE -->
                                        <Button Grid.Column="2"
                    Width="36"
                    Height="36"
                    Background="#FF6B81"
                    Foreground="White"
                    BorderThickness="0"
                    VerticalAlignment="Center"
                    Click="DeleteItem_Click"
                    Tag="{Binding}">

                                            <TextBlock Text=""
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                                        </Button>

                                    </Grid>

                                </Border>

                            </DataTemplate>

                        </ListView.ItemTemplate>

                    </ListView>


                    <!-- TOTAL + PAYMENT -->

                    <StackPanel Grid.Row="2">

                        <Grid Height="80"
                   Background="#070807"
                   Margin="0 10">

                            <StackPanel HorizontalAlignment="Right"
                             VerticalAlignment="Bottom"
                             Margin="10">

                                <TextBlock Text="TOTAL"
                                Foreground="White"
                                FontSize="14"/>

                                <TextBlock x:Name="TotalText"
                                Text="0.00 บาท"
                                Foreground="White"
                                FontSize="32"
                                FontWeight="Bold"
                                TextAlignment="Right"/>

                            </StackPanel>

                        </Grid>


                        <!-- PAYMENT BUTTON -->

                        <UniformGrid Columns="2" Margin="10">

                            <!-- PAY -->
                            <Button Height="65"
            Margin="6"
            Background="#FF6FA8"
            Foreground="White"
            FontSize="18"
            BorderThickness="0"
            Click="Pay_Click">

                                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                                    <TextBlock Text=""
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="20"
                       Margin="0 0 8 0"/>

                                    <TextBlock Text="ชำระเงิน"
                       FontWeight="Bold"/>

                                </StackPanel>

                            </Button>


                            <!-- CANCEL -->
                            <Button Height="65"
            Margin="6"
            Background="#FF6B6B"
            Foreground="White"
            FontSize="18"
            BorderThickness="0"
            Click="Cancel_Click">

                                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                                    <TextBlock Text=""
                       FontFamily="Segoe MDL2 Assets"
                       FontSize="20"
                       Margin="0 0 8 0"/>

                                    <TextBlock Text="ยกเลิก"
                       FontWeight="Bold"/>

                                </StackPanel>

                            </Button>

                        </UniformGrid>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>
</Page>
