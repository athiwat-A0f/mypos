<Window x:Class="mystock.Components.AlertDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="360"
        Height="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Opacity="0">

    <Grid x:Name="RootGrid">

        <!-- Animation Transform -->
        <Grid.RenderTransform>
            <ScaleTransform x:Name="scale"
                            ScaleX="0.8"
                            ScaleY="0.8"/>
        </Grid.RenderTransform>

        <Border CornerRadius="16"
                Background="#F8F9FA"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="2"
                                  Opacity="0.35"/>
            </Border.Effect>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Border x:Name="Header"
                        CornerRadius="16 16 0 0"
                        Background="#3498DB">

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="15 0">

                        <TextBlock x:Name="txtIcon"
                                   FontSize="26"
                                   Margin="0 0 8 0"/>

                        <TextBlock x:Name="txtTitle"
                                   FontSize="18"
                                   Foreground="White"
                                   FontWeight="Bold"/>

                    </StackPanel>

                </Border>


                <!-- BODY -->
                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center">

                    <TextBlock x:Name="txtMessage"
                               FontSize="16"
                               TextAlignment="Center"
                               Margin="20 15"
                               TextWrapping="Wrap"/>

                    <Button x:Name="btnOK"
                            Content="ตกลง"
                            Height="40"
                            Width="100"
                            HorizontalAlignment="Center"
                            Background="#3498DB"
                            Foreground="White"
                            BorderThickness="0"
                            Click="OK_Click">

                    </Button>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>

</Window>