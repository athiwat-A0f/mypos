<Page x:Class="mystock.Pages.StockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:mystock.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="650" d:DesignWidth="800"
      Title="StockPage">

    <Grid Background="#F4F6F9">

        <Grid Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>


            <!-- PRODUCT LIST CARD -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Padding="20"
                    Margin="0 0 15 0">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="15"
                                      ShadowDepth="2"
                                      Opacity="0.2"/>
                </Border.Effect>

                <DockPanel>

                    <TextBlock Text="📦 สต๊อกสินค้า"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0 0 0 15"
                               DockPanel.Dock="Top"/>

                    <DataGrid x:Name="StockGrid"
          AutoGenerateColumns="False"
          SelectionChanged="StockGrid_SelectionChanged"
          RowHeight="38"
          FontSize="16"
          Background="White"
          BorderThickness="0"
          GridLinesVisibility="None"
          HeadersVisibility="Column">

                        <!-- Remove default blue selection -->
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                        </DataGrid.Resources>

                        <!-- Header Style -->
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="18"/>
                                <Setter Property="Background" Value="#F3F4F6"/>
                                <Setter Property="Foreground" Value="#333"/>
                                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                <Setter Property="BorderThickness" Value="0 0 0 1"/>
                                <Setter Property="Padding" Value="10 6"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <!-- Row Style -->
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">

                                <Setter Property="Background" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="5"/>

                                <Style.Triggers>

                                    <!-- Hover -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FCE4EC"/>
                                    </Trigger>

                                    <!-- Selected -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#F8BBD0"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Trigger>

                                </Style.Triggers>

                            </Style>
                        </DataGrid.RowStyle>

                        <!-- Cell Style -->
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="8 4"/>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="ชื่อสินค้า"
                                                Binding="{Binding ProductName}"
                                                Width="250"/>

                            <DataGridTextColumn Header="ราคาขาย"
                                                Binding="{Binding Price}"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="คงเหลือ"
                                                Binding="{Binding Amount}"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                        </DataGrid.Columns>

                    </DataGrid>

                </DockPanel>

            </Border>


            <!-- FORM CARD -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="20">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="15"
                                      ShadowDepth="2"
                                      Opacity="0.2"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="📝 เพิ่ม / แก้ไขสต๊อกสินค้า"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="0 0 0 20"/>


                    <TextBlock Text="ชื่อสินค้า"/>
                    <TextBox x:Name="txtName"
                             Height="35"
                             Margin="0 5 0 15"
                             Padding="5"
                             IsEnabled="false"/>


                    <TextBlock Text="ราคาขาย"/>
                    <TextBox x:Name="txtPrice"
                             Height="35"
                             Margin="0 5 0 15"
                             Padding="5"
                             IsEnabled="false"/>

                    <TextBlock Text="จำนวน"/>
                    <TextBox x:Name="txtQty"
                              Height="35"
                              Margin="0 5 0 15"
                              Padding="5"
                              TextChanged="OnValueChanged"/>

                    <TextBlock Text="ราคาทุน"/>
                    <TextBox x:Name="txtCost"
                              Height="35"
                              Margin="0 5 0 15"
                              Padding="5"
                              TextChanged="OnValueChanged"/>

                    <TextBlock Text="ราคาทุนเฉลี่ย (ชิ้น)"/>
                    <TextBox x:Name="txtCostAvg"
                            Height="35"
                            Margin="0 5 0 15"
                            Padding="5"
                            IsEnabled="false"/>


                    <TextBlock Text="หมายเหตุ"/>
                    <TextBox x:Name="txtRemark"
                             Height="100"
                             Margin="0 5 0 15"
                             Padding="5"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>


                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left">

                        <Button Content="เพิ่ม"
                                Width="80"
                                Height="40"
                                Margin="0 0 10 0"
                                Background="#27AE60"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Click="StockIn_Click"/>

                        <Button Content="ลด"
                                Width="80"
                                Height="40"
                                Margin="0 0 10 0"
                                Background="#3498DB"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Click="StockOut_Click"/>

                        <Button Content="ยกเลิก"
                                Width="80"
                                Height="40"
                                Background="#E74C3C"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="Bold"
                                Click="Cancel_Click"/>

                    </StackPanel>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</Page>
