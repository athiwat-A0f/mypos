<Window x:Class="mystock.PayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="รับชำระเงิน"
        Height="350"
        Width="350"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">

        <TextBlock Text="ยอดชำระ"
                   FontSize="18" FontWeight="Bold"/>

        <TextBlock x:Name="TotalText"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0 10"/>

        <TextBlock Text="รับเงิน"/>

        <TextBox x:Name="CashBox"
         FontSize="20"
         Height="40"
         TextChanged="CashBox_TextChanged"
         PreviewTextInput="CashBox_PreviewTextInput"/>

        <TextBlock Text="เงินทอน"
                   Margin="0 10 0 0"/>

        <TextBlock x:Name="ChangeText"
                   FontSize="24"
                   FontWeight="Bold"/>

        <Button Content="ยืนยัน"
                Height="45"
                Margin="0 20 0 0"
                Click="Confirm_Click"
                Background="#27AE60"
                Foreground="White"/>

    </StackPanel>

</Window>