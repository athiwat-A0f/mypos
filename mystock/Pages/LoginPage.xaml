<Page x:Class="mystock.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:mystock.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">


    <Grid>

        <!-- Gradient Background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#4A90E2" Offset="0"/>
                <GradientStop Color="#6A5ACD" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Login Card -->
        <Border Width="350"
                Padding="35"
                Background="White"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="0"
                                  Opacity="0.3"/>
            </Border.Effect>

            <StackPanel>

                <!-- Title -->
                <TextBlock Text="MYPOS"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 25"/>

                <!-- Username -->
                <Border Background="#F5F5F5"
                        CornerRadius="6"
                        Padding="5"
                        Margin="0 5">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="&#xE77B;"
                                   FontFamily="Segoe MDL2 Assets"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="Gray"/>

                        <TextBox Grid.Column="1"
                                 x:Name="txtUser"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"/>
                    </Grid>

                </Border>

                <!-- Password -->
                <Border Background="#F5F5F5"
                        CornerRadius="6"
                        Padding="5"
                        Margin="0 10">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="&#xE72E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="Gray"/>

                        <PasswordBox Grid.Column="1"
                                     x:Name="txtPass"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontSize="14"/>
                    </Grid>

                </Border>

                <!-- Login Button -->
                <Button Content="LOGIN"
                        Height="40"
                        Margin="0 20 0 0"
                        Background="#4A90E2"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="Bold"
                        IsDefault="True"
                        Click="Login_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Page>
